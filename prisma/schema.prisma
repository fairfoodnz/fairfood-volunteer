// Fair Food volunteer scheduling
// Programs (Kai Box, Conscious Kitchen, Inclusive) have recurring shifts.
// Volunteers register, complete a questionnaire, then book shifts.
// Admins manage rosters, attendance, and resource documents.

generator client {
  provider = "prisma-client-js"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

enum Role {
  VOLUNTEER
  ADMIN
}

enum BookingStatus {
  CONFIRMED
  CANCELLED
  ATTENDED
  NO_SHOW
}

enum HeardAbout {
  FRIEND
  SOCIAL
  SEARCH
  WORKPLACE
  EVENT
  OTHER
}

enum DocumentCategory {
  HANDBOOK
  HEALTH_SAFETY
  GETTING_HERE
  FORMS
  OTHER
}

// Who can download a Document via /api/documents/[id]. Default VOLUNTEER —
// the safe assumption for new uploads. Anything that goes on the public
// marketing site must be marked PUBLIC explicitly; ADMIN is for internal
// guidance or sensitive material (police-check templates, etc.).
enum DocumentVisibility {
  PUBLIC
  VOLUNTEER
  ADMIN
}

model User {
  id              String              @id @default(cuid())
  email           String              @unique
  // Null until the volunteer clicks the verification link emailed at sign-up.
  // Soft gate: an unverified account can browse + fill the questionnaire but
  // bookShiftAction refuses until this is set. Existing accounts were
  // grandfathered (backfilled to createdAt) in the adding migration.
  emailVerifiedAt DateTime?
  // Null for accounts that only ever signed in with Google or a passkey — they
  // never set a password. signInAction must treat null as "no password login"
  // (still timing-safe). A password reset can later populate it (the user
  // controls the inbox), which simply adds password login as another option.
  passwordHash    String?
  firstName       String
  // Null for mononyms and OAuth identities that only supply a given name.
  // Display code must treat a missing last name gracefully (see lib/users.ts).
  lastName        String?
  phone           String?
  role            Role                @default(VOLUNTEER)
  pronouns        String?
  emergencyName   String?
  emergencyPhone  String?
  notes           String?             @db.Text
  accessNeeds     String?             @db.Text

  // Onboarding questionnaire — required before booking a shift.
  // profileCompletedAt being non-null gates bookShiftAction.
  birthday          DateTime?
  heardAbout        HeardAbout?
  heardAboutOther   String?
  whyInterested     String?             @db.Text
  arrestHistory     Boolean?
  arrestDetails     String?             @db.Text
  healthConditions  Boolean?
  healthDetails     String?             @db.Text
  profileCompletedAt DateTime?
  // Admin can mark a flagged volunteer as reviewed (kept private to coordinators).
  flagReviewedAt    DateTime?

  createdAt       DateTime            @default(now())
  updatedAt       DateTime            @updatedAt
  // True when this account was created by an admin importing a roster (CSV/XLSX)
  // and the volunteer hasn't yet redeemed the invite link. Lets the UI show
  // "Awaiting claim" badges and gate filters without re-deriving from token rows.
  // Cleared at first invite redemption (see VolunteerInvite.usedAt path).
  importedAt        DateTime?

  bookings           Booking[]
  sessions           Session[]
  passwordResets     PasswordResetToken[]
  emailVerifications EmailVerificationToken[]
  invites            VolunteerInvite[]
  // Invites this admin sent out (for the audit trail). SetNull on the FK side
  // means deleting an admin nulls the column rather than nuking the invite
  // history — see VolunteerInvite.invitedBy.
  sentInvites        VolunteerInvite[]   @relation("InvitedByAdmin")
  oauthAccounts      OAuthAccount[]
  passkeys           Passkey[]
  uploadedDocs       Document[]          @relation("DocumentUploader")
}

// A linked third-party identity (currently only Google). One row per
// (provider, providerAccountId) — re-logins match deterministically on the
// provider's stable subject id, not the email (emails can change/transfer).
// A User can have several (e.g. Google + a future provider). Auto-linked to an
// existing password account when Google reports the email as verified.
model OAuthAccount {
  id                String   @id @default(cuid())
  userId            String
  user              User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  provider          String
  providerAccountId String
  createdAt         DateTime @default(now())

  @@unique([provider, providerAccountId])
  // One identity per (provider, account) AND at most one account per provider
  // per user — backs the "one Google per user" rule at the DB level so a
  // concurrent double-connect can't slip past the application guard (TOCTOU).
  @@unique([userId, provider])
  @@index([userId])
}

// A registered WebAuthn credential (passkey). Discoverable/resident credentials
// so the sign-in page can offer usernameless login. publicKey is the raw COSE
// key bytes; counter is the signature counter (0 for most platform passkeys).
// credentialId is the base64url credential id returned by the authenticator.
model Passkey {
  id           String    @id @default(cuid())
  userId       String
  user         User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  credentialId String    @unique
  publicKey    Bytes
  counter      Int       @default(0)
  // CSV of AuthenticatorTransport values ("internal,hybrid", "usb" …) — used to
  // hint the browser on subsequent ceremonies.
  transports   String?
  deviceType   String?
  backedUp     Boolean   @default(false)
  // User-facing label so they can tell devices apart ("MacBook", "iPhone").
  name         String
  createdAt    DateTime  @default(now())
  lastUsedAt   DateTime?

  @@index([userId])
}

// Server-side session record. Only the SHA-256 hash of the raw token is
// stored — the cookie holds the raw token, lookups hash the cookie value
// first. Same threat model as PasswordResetToken / EmailVerificationToken /
// VolunteerInvite: a leaked DB backup or read-only SQL injection must not
// yield working session cookies.
model Session {
  id        String   @id @default(cuid())
  tokenHash String   @unique
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  expiresAt DateTime
  createdAt DateTime @default(now())

  @@index([userId])
}

// Single-use password reset tokens. We store only a SHA-256 hash of the
// token, never the raw value: a leaked row must not be redeemable, since a
// reset grants full account takeover. Session.tokenHash uses the same
// pattern; redeeming a reset wipes all sessions for the user.
model PasswordResetToken {
  id        String    @id @default(cuid())
  tokenHash String    @unique
  userId    String
  user      User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  expiresAt DateTime
  usedAt    DateTime?
  createdAt DateTime  @default(now())

  @@index([userId])
}

// Single-use volunteer-invite tokens — issued when an admin bulk-imports
// volunteers from a roster (CSV/XLSX) and clicks "Send invites". Same threat
// model as PasswordResetToken: only the SHA-256 hash of the raw token is
// stored, never the raw value, so a leaked row can't be redeemed. One live
// token per user — the issuer drops prior unredeemed ones before creating a
// new one (so "Resend invite" is safe to spam). 7-day TTL: invites are sent
// proactively by a coordinator, not in response to a user action, so they
// should outlive a casual delay before the volunteer reads their email.
// Redeeming this token sets a password AND clears User.importedAt AND verifies
// the email (in the same transaction as resetPasswordAction's tail).
model VolunteerInvite {
  id        String    @id @default(cuid())
  tokenHash String    @unique
  userId    String
  user      User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  // Provenance: which admin issued this invite. The FK uses onDelete: SetNull
  // so deleting an admin nulls the column rather than cascading and nuking
  // the invite — the audit trail survives an admin leaving the org. Pure
  // record-keeping: the action requireAdmin()'s on its own.
  invitedById String?
  invitedBy   User?   @relation("InvitedByAdmin", fields: [invitedById], references: [id], onDelete: SetNull)
  expiresAt DateTime
  usedAt    DateTime?
  createdAt DateTime  @default(now())

  @@index([userId])
  @@index([invitedById])
}

// Single-use email-verification tokens. Same threat model as
// PasswordResetToken: only the SHA-256 hash is stored, never the raw value, so
// a leaked row can't be redeemed. One live token per user (the issuer drops
// prior unredeemed ones). 24h TTL.
model EmailVerificationToken {
  id        String    @id @default(cuid())
  tokenHash String    @unique
  userId    String
  user      User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  expiresAt DateTime
  usedAt    DateTime?
  createdAt DateTime  @default(now())

  @@index([userId])
}

model Program {
  id           String   @id @default(cuid())
  // URL-friendly identifier (e.g. "kai-box"). Free-form so coordinators can add
  // their own programmes — no longer constrained to a Prisma enum.
  slug         String   @unique
  title        String
  tagline      String
  description  String   @db.Text
  // Static path for seeded programmes (e.g. "/photos/kai-box.webp"). For
  // uploaded images this is null and imageKey points at the S3/Garage object;
  // the UI serves those via /api/programmes/[id]/image.
  imageUrl     String?
  imageKey     String?
  location     String   @default("624 Rosebank Road, Avondale, Tāmaki Makaurau")
  contactEmail String?
  contactPhone String?
  // Free-text "where you'll be / getting here" blurb on the detail page.
  gettingHere  String?  @db.Text
  // Editorial day-range shown under the title on programme cards (e.g.
  // "Mon – Fri"). Not derived from shifts — it's a human summary the
  // coordinator controls; null hides the line.
  schedule     String?
  // Card theme key — see src/lib/programme-theme.ts.
  theme        String   @default("cream")
  order        Int      @default(0)
  active       Boolean  @default(true)
  shifts       Shift[]
  templates    ShiftTemplate[]
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
}

// Reusable per-programme shift definition. Coordinators bulk-generate Shift rows
// from these over a date range + selected weekdays. startTime/endTime are NZ
// local wall-clock "HH:MM" (24h); each generated date is converted to a UTC
// instant DST-aware (see src/lib/schedule.ts), so a 9am template stays 9am
// across the daylight-saving boundary. Generated shifts carry no FK back here —
// templates are purely a creation convenience.
model ShiftTemplate {
  id        String   @id @default(cuid())
  programId String
  program   Program  @relation(fields: [programId], references: [id], onDelete: Cascade)
  label     String
  startTime String
  endTime   String
  capacity  Int      @default(8)
  notes     String?  @db.Text
  active    Boolean  @default(true)
  order     Int      @default(0)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([programId, order])
}

model Shift {
  id        String    @id @default(cuid())
  programId String
  program   Program   @relation(fields: [programId], references: [id], onDelete: Cascade)
  startsAt  DateTime
  endsAt    DateTime
  capacity  Int       @default(8)
  notes     String?   @db.Text
  cancelled Boolean   @default(false)
  bookings  Booking[]
  blocks    SlotBlock[]
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt

  @@index([programId, startsAt])
  @@index([startsAt])
}

// An admin-reserved hold on a Shift — slots a coordinator is keeping back for
// an off-platform group (corporate day, school class, private booking, etc.).
// Carries no User: it reduces public + admin availability exactly like a
// confirmed Booking but is never shown to volunteers. A shift can have several
// independent holds; each is added/removed on its own and carries its own note.
model SlotBlock {
  id        String   @id @default(cuid())
  shiftId   String
  shift     Shift    @relation(fields: [shiftId], references: [id], onDelete: Cascade)
  slots     Int
  note      String?  @db.Text
  createdAt DateTime @default(now())

  @@index([shiftId])
}

model Booking {
  id        String        @id @default(cuid())
  userId    String
  user      User          @relation(fields: [userId], references: [id], onDelete: Cascade)
  shiftId   String
  shift     Shift         @relation(fields: [shiftId], references: [id], onDelete: Cascade)
  status    BookingStatus @default(CONFIRMED)
  notes     String?       @db.Text
  createdAt DateTime      @default(now())
  updatedAt DateTime      @updatedAt

  @@unique([userId, shiftId])
  @@index([shiftId, status])
}

// Volunteer-facing documents (handbook, H&S, map etc.) stored in Garage / S3.
// Soft-deleted via deletedAt so admin actions stay reversible until a sweep.
model Document {
  id           String              @id @default(cuid())
  title        String
  description  String?             @db.Text
  category     DocumentCategory    @default(OTHER)
  // Defaults to VOLUNTEER — the safe assumption for new uploads. Anything
  // public must be flipped to PUBLIC explicitly; sensitive material flips
  // to ADMIN. /api/documents/[id] gates on this; /resources shows only
  // PUBLIC + VOLUNTEER (admins manage their own at /admin/documents).
  visibility   DocumentVisibility  @default(VOLUNTEER)
  objectKey    String              @unique
  mimeType     String
  sizeBytes    Int
  uploadedById String?
  uploadedBy   User?               @relation("DocumentUploader", fields: [uploadedById], references: [id], onDelete: SetNull)
  deletedAt    DateTime?
  createdAt    DateTime            @default(now())
  updatedAt    DateTime            @updatedAt

  @@index([category, deletedAt])
  @@index([visibility, deletedAt])
}

// Fair Food volunteer scheduling
// Programs (Kai Box, Conscious Kitchen, Inclusive) have recurring shifts.
// Volunteers register, complete a questionnaire, then book shifts.
// Admins manage rosters, attendance, and resource documents.

generator client {
  provider = "prisma-client-js"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

enum Role {
  VOLUNTEER
  ADMIN
}

enum BookingStatus {
  CONFIRMED
  CANCELLED
  ATTENDED
  NO_SHOW
}

enum HeardAbout {
  FRIEND
  SOCIAL
  SEARCH
  WORKPLACE
  EVENT
  OTHER
}

enum DocumentCategory {
  HANDBOOK
  HEALTH_SAFETY
  GETTING_HERE
  FORMS
  OTHER
}

model User {
  id              String              @id @default(cuid())
  email           String              @unique
  // Null until the volunteer clicks the verification link emailed at sign-up.
  // Soft gate: an unverified account can browse + fill the questionnaire but
  // bookShiftAction refuses until this is set. Existing accounts were
  // grandfathered (backfilled to createdAt) in the adding migration.
  emailVerifiedAt DateTime?
  // Null for accounts that only ever signed in with Google or a passkey — they
  // never set a password. signInAction must treat null as "no password login"
  // (still timing-safe). A password reset can later populate it (the user
  // controls the inbox), which simply adds password login as another option.
  passwordHash    String?
  name            String
  phone           String?
  role            Role                @default(VOLUNTEER)
  pronouns        String?
  emergencyName   String?
  emergencyPhone  String?
  notes           String?             @db.Text
  accessNeeds     String?             @db.Text

  // Onboarding questionnaire — required before booking a shift.
  // profileCompletedAt being non-null gates bookShiftAction.
  birthday          DateTime?
  heardAbout        HeardAbout?
  heardAboutOther   String?
  whyInterested     String?             @db.Text
  arrestHistory     Boolean?
  arrestDetails     String?             @db.Text
  healthConditions  Boolean?
  healthDetails     String?             @db.Text
  profileCompletedAt DateTime?
  // Admin can mark a flagged volunteer as reviewed (kept private to coordinators).
  flagReviewedAt    DateTime?

  createdAt       DateTime            @default(now())
  updatedAt       DateTime            @updatedAt
  bookings           Booking[]
  sessions           Session[]
  passwordResets     PasswordResetToken[]
  emailVerifications EmailVerificationToken[]
  oauthAccounts      OAuthAccount[]
  passkeys           Passkey[]
  uploadedDocs       Document[]          @relation("DocumentUploader")
}

// A linked third-party identity (currently only Google). One row per
// (provider, providerAccountId) — re-logins match deterministically on the
// provider's stable subject id, not the email (emails can change/transfer).
// A User can have several (e.g. Google + a future provider). Auto-linked to an
// existing password account when Google reports the email as verified.
model OAuthAccount {
  id                String   @id @default(cuid())
  userId            String
  user              User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  provider          String
  providerAccountId String
  createdAt         DateTime @default(now())

  @@unique([provider, providerAccountId])
  @@index([userId])
}

// A registered WebAuthn credential (passkey). Discoverable/resident credentials
// so the sign-in page can offer usernameless login. publicKey is the raw COSE
// key bytes; counter is the signature counter (0 for most platform passkeys).
// credentialId is the base64url credential id returned by the authenticator.
model Passkey {
  id           String    @id @default(cuid())
  userId       String
  user         User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  credentialId String    @unique
  publicKey    Bytes
  counter      Int       @default(0)
  // CSV of AuthenticatorTransport values ("internal,hybrid", "usb" …) — used to
  // hint the browser on subsequent ceremonies.
  transports   String?
  deviceType   String?
  backedUp     Boolean   @default(false)
  // User-facing label so they can tell devices apart ("MacBook", "iPhone").
  name         String
  createdAt    DateTime  @default(now())
  lastUsedAt   DateTime?

  @@index([userId])
}

model Session {
  id        String   @id @default(cuid())
  token     String   @unique
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  expiresAt DateTime
  createdAt DateTime @default(now())

  @@index([token])
}

// Single-use password reset tokens. We store only a SHA-256 hash of the
// token, never the raw value: a leaked row must not be redeemable, since a
// reset grants full account takeover. (Session.token is stored raw by
// contrast — lower value, and resets wipe all sessions anyway.)
model PasswordResetToken {
  id        String    @id @default(cuid())
  tokenHash String    @unique
  userId    String
  user      User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  expiresAt DateTime
  usedAt    DateTime?
  createdAt DateTime  @default(now())

  @@index([userId])
}

// Single-use email-verification tokens. Same threat model as
// PasswordResetToken: only the SHA-256 hash is stored, never the raw value, so
// a leaked row can't be redeemed. One live token per user (the issuer drops
// prior unredeemed ones). 24h TTL.
model EmailVerificationToken {
  id        String    @id @default(cuid())
  tokenHash String    @unique
  userId    String
  user      User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  expiresAt DateTime
  usedAt    DateTime?
  createdAt DateTime  @default(now())

  @@index([userId])
}

model Program {
  id           String   @id @default(cuid())
  // URL-friendly identifier (e.g. "kai-box"). Free-form so coordinators can add
  // their own programmes — no longer constrained to a Prisma enum.
  slug         String   @unique
  title        String
  tagline      String
  description  String   @db.Text
  // Static path for seeded programmes (e.g. "/photos/kai-box.webp"). For
  // uploaded images this is null and imageKey points at the S3/Garage object;
  // the UI serves those via /api/programmes/[id]/image.
  imageUrl     String?
  imageKey     String?
  location     String   @default("624 Rosebank Road, Avondale, Tāmaki Makaurau")
  contactEmail String?
  contactPhone String?
  // Free-text "where you'll be / getting here" blurb on the detail page.
  gettingHere  String?  @db.Text
  // Card theme key — see src/lib/programme-theme.ts.
  theme        String   @default("cream")
  order        Int      @default(0)
  active       Boolean  @default(true)
  shifts       Shift[]
  templates    ShiftTemplate[]
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
}

// Reusable per-programme shift definition. Coordinators bulk-generate Shift rows
// from these over a date range + selected weekdays. startTime/endTime are NZ
// local wall-clock "HH:MM" (24h); each generated date is converted to a UTC
// instant DST-aware (see src/lib/schedule.ts), so a 9am template stays 9am
// across the daylight-saving boundary. Generated shifts carry no FK back here —
// templates are purely a creation convenience.
model ShiftTemplate {
  id        String   @id @default(cuid())
  programId String
  program   Program  @relation(fields: [programId], references: [id], onDelete: Cascade)
  label     String
  startTime String
  endTime   String
  capacity  Int      @default(8)
  notes     String?  @db.Text
  active    Boolean  @default(true)
  order     Int      @default(0)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([programId, order])
}

model Shift {
  id        String    @id @default(cuid())
  programId String
  program   Program   @relation(fields: [programId], references: [id], onDelete: Cascade)
  startsAt  DateTime
  endsAt    DateTime
  capacity  Int       @default(8)
  notes     String?   @db.Text
  cancelled Boolean   @default(false)
  bookings  Booking[]
  blocks    SlotBlock[]
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt

  @@index([programId, startsAt])
  @@index([startsAt])
}

// An admin-reserved hold on a Shift — slots a coordinator is keeping back for
// an off-platform group (corporate day, school class, private booking, etc.).
// Carries no User: it reduces public + admin availability exactly like a
// confirmed Booking but is never shown to volunteers. A shift can have several
// independent holds; each is added/removed on its own and carries its own note.
model SlotBlock {
  id        String   @id @default(cuid())
  shiftId   String
  shift     Shift    @relation(fields: [shiftId], references: [id], onDelete: Cascade)
  slots     Int
  note      String?  @db.Text
  createdAt DateTime @default(now())

  @@index([shiftId])
}

model Booking {
  id        String        @id @default(cuid())
  userId    String
  user      User          @relation(fields: [userId], references: [id], onDelete: Cascade)
  shiftId   String
  shift     Shift         @relation(fields: [shiftId], references: [id], onDelete: Cascade)
  status    BookingStatus @default(CONFIRMED)
  notes     String?       @db.Text
  createdAt DateTime      @default(now())
  updatedAt DateTime      @updatedAt

  @@unique([userId, shiftId])
  @@index([shiftId, status])
}

// Volunteer-facing documents (handbook, H&S, map etc.) stored in Garage / S3.
// Soft-deleted via deletedAt so admin actions stay reversible until a sweep.
model Document {
  id           String            @id @default(cuid())
  title        String
  description  String?           @db.Text
  category     DocumentCategory  @default(OTHER)
  objectKey    String            @unique
  mimeType     String
  sizeBytes    Int
  uploadedById String?
  uploadedBy   User?             @relation("DocumentUploader", fields: [uploadedById], references: [id], onDelete: SetNull)
  deletedAt    DateTime?
  createdAt    DateTime          @default(now())
  updatedAt    DateTime          @updatedAt

  @@index([category, deletedAt])
}

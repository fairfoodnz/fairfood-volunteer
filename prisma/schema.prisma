// Fair Food volunteer scheduling
// Programs (Kai Box, Conscious Kitchen, Inclusive) have recurring shifts.
// Volunteers register, complete a questionnaire, then book shifts.
// Admins manage rosters, attendance, and resource documents.

generator client {
  provider = "prisma-client-js"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

enum Role {
  VOLUNTEER
  ADMIN
}

enum ProgramSlug {
  KAI_BOX
  CONSCIOUS_KITCHEN
  INCLUSIVE
}

enum BookingStatus {
  CONFIRMED
  CANCELLED
  ATTENDED
  NO_SHOW
}

enum HeardAbout {
  FRIEND
  SOCIAL
  SEARCH
  WORKPLACE
  EVENT
  OTHER
}

enum DocumentCategory {
  HANDBOOK
  HEALTH_SAFETY
  GETTING_HERE
  FORMS
  OTHER
}

model User {
  id              String              @id @default(cuid())
  email           String              @unique
  passwordHash    String
  name            String
  phone           String?
  role            Role                @default(VOLUNTEER)
  pronouns        String?
  emergencyName   String?
  emergencyPhone  String?
  notes           String?             @db.Text
  accessNeeds     String?             @db.Text

  // Onboarding questionnaire — required before booking a shift.
  // profileCompletedAt being non-null gates bookShiftAction.
  birthday          DateTime?
  heardAbout        HeardAbout?
  heardAboutOther   String?
  whyInterested     String?             @db.Text
  arrestHistory     Boolean?
  arrestDetails     String?             @db.Text
  healthConditions  Boolean?
  healthDetails     String?             @db.Text
  profileCompletedAt DateTime?
  // Admin can mark a flagged volunteer as reviewed (kept private to coordinators).
  flagReviewedAt    DateTime?

  createdAt       DateTime            @default(now())
  updatedAt       DateTime            @updatedAt
  bookings        Booking[]
  sessions        Session[]
  uploadedDocs    Document[]          @relation("DocumentUploader")
}

model Session {
  id        String   @id @default(cuid())
  token     String   @unique
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  expiresAt DateTime
  createdAt DateTime @default(now())

  @@index([token])
}

model Program {
  id          String      @id @default(cuid())
  slug        ProgramSlug @unique
  title       String
  tagline     String
  description String      @db.Text
  imageUrl    String?
  location    String      @default("624 Rosebank Road, Avondale, Tāmaki Makaurau")
  order       Int         @default(0)
  active      Boolean     @default(true)
  shifts      Shift[]
  createdAt   DateTime    @default(now())
  updatedAt   DateTime    @updatedAt
}

model Shift {
  id        String    @id @default(cuid())
  programId String
  program   Program   @relation(fields: [programId], references: [id], onDelete: Cascade)
  startsAt  DateTime
  endsAt    DateTime
  capacity  Int       @default(8)
  notes     String?   @db.Text
  cancelled Boolean   @default(false)
  bookings  Booking[]
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt

  @@index([programId, startsAt])
  @@index([startsAt])
}

model Booking {
  id        String        @id @default(cuid())
  userId    String
  user      User          @relation(fields: [userId], references: [id], onDelete: Cascade)
  shiftId   String
  shift     Shift         @relation(fields: [shiftId], references: [id], onDelete: Cascade)
  status    BookingStatus @default(CONFIRMED)
  notes     String?       @db.Text
  createdAt DateTime      @default(now())
  updatedAt DateTime      @updatedAt

  @@unique([userId, shiftId])
  @@index([shiftId, status])
}

// Volunteer-facing documents (handbook, H&S, map etc.) stored in Garage / S3.
// Soft-deleted via deletedAt so admin actions stay reversible until a sweep.
model Document {
  id           String            @id @default(cuid())
  title        String
  description  String?           @db.Text
  category     DocumentCategory  @default(OTHER)
  objectKey    String            @unique
  mimeType     String
  sizeBytes    Int
  uploadedById String?
  uploadedBy   User?             @relation("DocumentUploader", fields: [uploadedById], references: [id], onDelete: SetNull)
  deletedAt    DateTime?
  createdAt    DateTime          @default(now())
  updatedAt    DateTime          @updatedAt

  @@index([category, deletedAt])
}

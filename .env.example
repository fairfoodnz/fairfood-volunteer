DATABASE_URL="postgresql://user:password@host:5432/dbname?schema=public"
AUTH_SECRET="generate-with-openssl-rand-hex-32"
# Public origin of the volunteer app. Production: https://volunteer.fairfood.org.nz
NEXT_PUBLIC_APP_URL="http://localhost:3000"

# Object storage (Garage S3 locally, Garage S3 in prod via Coolify).
# Local values come from `scripts/garage-init.sh`.
S3_ENDPOINT="http://localhost:3900"
S3_REGION="garage"
S3_BUCKET="fairfood"
S3_ACCESS_KEY_ID=""
S3_SECRET_ACCESS_KEY=""

# Transactional email (Resend). Leave RESEND_API_KEY empty in dev — emails are
# logged to the console instead of sent. In production it MUST be set or sends
# throw. EMAIL_FROM must be on a domain verified in Resend (fairfood.org.nz).
RESEND_API_KEY=""
EMAIL_FROM="Fair Food NZ <volunteer@fairfood.org.nz>"

# Google sign-in (optional in dev — the "Continue with Google" button is hidden
# when these are unset). Create an OAuth 2.0 Client ID (type: Web application)
# in Google Cloud Console and add the authorised redirect URI
# <NEXT_PUBLIC_APP_URL>/auth/google/callback — e.g.
# http://localhost:3000/auth/google/callback locally and
# https://volunteer.fairfood.org.nz/auth/google/callback in production.
GOOGLE_CLIENT_ID=""
GOOGLE_CLIENT_SECRET=""

# Passkeys (WebAuthn) need no extra config — the relying-party ID and origin
# are derived from NEXT_PUBLIC_APP_URL, and localhost is a secure context so
# they work in `npm run dev` out of the box.

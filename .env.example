DATABASE_URL="postgresql://user:password@host:5432/dbname?schema=public"
AUTH_SECRET="generate-with-openssl-rand-hex-32"
# Public origin of the volunteer app. Production: https://volunteer.fairfood.org.nz
NEXT_PUBLIC_APP_URL="http://localhost:3000"

# Object storage (Garage S3 locally, Garage S3 in prod via Coolify).
# Local values come from `scripts/garage-init.sh`.
S3_ENDPOINT="http://localhost:3900"
S3_REGION="garage"
S3_BUCKET="fairfood"
S3_ACCESS_KEY_ID=""
S3_SECRET_ACCESS_KEY=""
